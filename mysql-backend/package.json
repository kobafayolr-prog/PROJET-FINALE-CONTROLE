{
  "name": "timetrack-bgfibank-mysql",
  "version": "1.0.0",
  "description": "TimeTrack BGFIBank - Backend Node.js + Express + MySQL2",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop timetrack",
    "pm2:restart": "pm2 restart timetrack",
    "pm2:logs": "pm2 logs timetrack --nostream",
    "db:init": "node scripts/init-db.js",
    "db:seed": "node scripts/seed-db.js"
  },
  "dependencies": {
    "express": "^4.18.3",
    "mysql2": "^3.9.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
