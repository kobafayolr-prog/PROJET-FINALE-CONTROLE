# ============================================================
# TimeTrack BGFIBank - Variables d'environnement
# Copiez ce fichier en .env et adaptez les valeurs
# ============================================================

# Port du serveur
PORT=3000

# MySQL - Connexion
DB_HOST=localhost
DB_PORT=3306
DB_USER=timetrack_user
DB_PASSWORD=TimeTrack@BGFIBank2024!
DB_NAME=timetrack_db

# Pour init-db.js (mot de passe root MySQL)
DB_ROOT_PASSWORD=

# Sécurité JWT (CHANGEZ CETTE VALEUR EN PRODUCTION !)
# Générez un secret aléatoire : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=timetrack-bgfibank-secret-2024-x9k2p7m

# CORS - Origines autorisées (séparées par des virgules)
# Exemple: http://localhost:3000,https://timetrack.bgfibank.com
# Laisser vide ou * pour autoriser toutes les origines (NON recommandé en production)
ALLOWED_ORIGINS=
