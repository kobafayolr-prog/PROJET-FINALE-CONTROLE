# TimeTrack BGFIBank - Configuration Environment Variables
# COPIEZ ce fichier vers .env et modifiez les valeurs

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000

# ============================================
# JWT SECURITY
# ============================================
# ⚠️ IMPORTANT: Changez cette valeur en production !
# Générer un secret fort: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGEZ-CE-SECRET-EN-PRODUCTION-min-32-caracteres!
JWT_EXPIRY_SECONDS=28800

# ============================================
# MYSQL DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=timetrack_user
DB_PASSWORD=TimeTrack@BGFIBank2024!
DB_NAME=timetrack_db

# ============================================
# CORS CONFIGURATION
# ============================================
# En développement: http://localhost:3000
# En production: https://votre-domaine.bgfibank.com
# Plusieurs domaines: https://domain1.com,https://domain2.com
# Tous les domaines (⚠️ DANGEREUX): *
ALLOWED_ORIGINS=http://localhost:3000

# ============================================
# LOGGING (optionnel)
# ============================================
LOG_LEVEL=info
